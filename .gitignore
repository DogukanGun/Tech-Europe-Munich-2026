# Environment secrets — NEVER commit
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / Editor
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store

# ADK session data
.adk/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
